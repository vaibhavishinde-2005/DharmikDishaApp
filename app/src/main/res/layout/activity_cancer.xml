<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Cancer">

    <!-- 🔹 Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarCancer"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/system_on_error_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Cancer"
        app:titleTextColor="#FFFFFF" />

    <!-- 🔹 Scroll area for content -->
    <ScrollView
        android:id="@+id/scrollViewCancer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarCancer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Cancer Symbol -->
            <ImageView
                android:id="@+id/cancerSymbol"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/cancer"
                android:contentDescription="Cancer Icon" />

            <!-- Cancer Title -->
            <TextView
                android:id="@+id/cancerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancer(कर्क)"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingTop="12dp" />

            <!-- Cancer Description -->
            <TextView
                android:id="@+id/cancerDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancer is known for emotional depth, intuition, and nurturing nature. People born under Cancer are sensitive, caring, and protective of loved ones. They value home, family, and emotional security. Although empathetic and loyal, they can sometimes be moody or overly protective."
                android:textSize="16sp"
                android:paddingTop="16dp"
                android:lineSpacingExtra="4dp" />

            <!-- Traits Header -->
            <TextView
                android:id="@+id/traitsHeaderCancer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Traits"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Traits List -->
            <TextView
                android:id="@+id/traitsListCancer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Nurturing\n• Emotional\n• Intuitive\n• Protective\n• Loyal\n• Sensitive"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

            <!-- Compatible Signs Header -->
            <TextView
                android:id="@+id/compatibleHeaderCancer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Compatible Signs"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Compatible Signs List -->
            <TextView
                android:id="@+id/compatibleSignsCancer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Taurus\n• Virgo\n• Scorpio\n• Pisces"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
