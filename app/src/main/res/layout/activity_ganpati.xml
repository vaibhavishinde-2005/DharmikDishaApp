<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aartibackground"
    tools:context=".Ganpati">



    <!-- TOP TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/system_on_error_dark"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Shree Ganapati Aarti">
    </androidx.appcompat.widget.Toolbar>

    <!-- SCROLLABLE GANAPATI AARTI MEDIUM LENGTH -->
    <ScrollView
        android:id="@+id/scrollAarti"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/aartiText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#5A3A1A"
            android:textSize="20dp"
            android:layout_marginTop="30dp"
            android:lineSpacingExtra="6dp"
            android:textStyle="bold"
            android:text="Jai Ganesh Jai Ganesh Deva,\n
Mata Jaki Parvati Deva.\n
Bhakton Ke Dukh Door Kare,\n
Sukh Sampatti Deva.\n\n

Mooshak Vahan Rajat Mandit,\n
Modak Priya Prabhu Sundar.\n
Trishul Pash Ankush Dharan,\n
Mangal Murti Vinayak Vardar.\n\n

Dukh Harta Sukh Karta,\n
Vighna Vinashak Deva.\n
Shraddha Se Jo Pooje Tumko,\n
Kripa Barsao Deva.\n\n

Sindoor Laga Sohe Shobhit,\n
Lambodar Roop Manmohan.\n
Gauri Nandan Kar Do Kripa,\n
Sada Raho Dayavan.\n\n

Jai Ganesh Jai Ganesh Deva,\n
Bhakta Janon Ke Sukhdaata.\n
Mangal Murti Ganapati,\n
Raksha Karo Bhagwanta." />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
