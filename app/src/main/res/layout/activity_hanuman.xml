<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aartibackground"
    tools:context=".hanuman">

    <!-- TOP TOOLBAR WITH BACK ICON -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/system_on_error_dark"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="Shree Hanuman Aarti">
    </androidx.appcompat.widget.Toolbar>

    <!-- SCROLLABLE HANUMAN AARTI -->
    <ScrollView
        android:id="@+id/scrollAarti"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/aartiText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#5A3A1A"
            android:textSize="20dp"
            android:layout_marginTop="30dp"
            android:lineSpacingExtra="6dp"
            android:textStyle="bold"
            android:text="Aarti Kije Hanuman Lala Ki\n
Dushtaraj Ka Daman Kiya Tha Bal Ki\n\n
Bajrang Bali Ki Jai Bajrang Bali Ki\n
Sankat Mochan Naam Tiharo\n\n
Ram Lakshman Janki Seva\n
Lene Ko Jag Mein Aayo\n\n
Aarti Kije Hanuman Lala Ki\n
Dushtaraj Ka Daman Kiya Tha Bal Ki\n\n
Laal Deh Laal Mukut Shobhit\n
Tilak Charu Maathe Lagayo\n\n
Bajrang Bali Ki Jai Bajrang Bali Ki\n
Sankat Mochan Naam Tiharo" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
