<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aartibackground"
    tools:context=".krishan">

    <!-- TOP TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbarKrishna"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/system_on_error_dark"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="Shree Krishna Aarti" />

    <!-- SCROLLABLE KRISHNA AARTI -->
    <ScrollView
        android:id="@+id/scrollAartiKrishna"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbarKrishna"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/aartiTextKrishna"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#5A3A1A"
            android:textSize="22sp"
            android:lineSpacingExtra="6dp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"

            android:text="Aarti Kunj Bihari Ki\n
Sri Girdhar Krishna Murari Ki\n\n

Gale Mein Baijanti Mala\n
Kundan Kiritin Shobha Bala\n
Kundal Shobhit Kari Jugal\n
Nahi Ko Tulk Ucchari Ki\n\n

Aarti Kunj Bihari Ki\n
Sri Girdhar Krishna Murari Ki\n\n

Kanchan Thaal Virajat\n
Neel Kamal Par Raajat\n
Mrigmad Sugandh Lagaavat\n
Hari Ko Laagi Piyaari Ki\n\n

Nanda Nandan Vishwa Vihari\n
Gop Gopi Man Mohan Hari\n
Ras Rasik Madhusudhan Murari\n
Gao Sab Mil Pyari Ki\n\n

Aarti Kunj Bihari Ki\n
Sri Girdhar Krishna Murari Ki" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>