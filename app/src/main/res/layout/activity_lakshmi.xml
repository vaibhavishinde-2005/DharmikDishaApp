<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aartibackground"
    tools:context=".Lakshmi">

    <!-- TOP TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/system_on_error_dark"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Shree Lakshmi Aarti">
    </androidx.appcompat.widget.Toolbar>

    <!-- SCROLLABLE LAKSHMI AARTI MEDIUM LENGTH -->
    <ScrollView
        android:id="@+id/scrollAarti"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/aartiText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#5A3A1A"
            android:textSize="20dp"
            android:layout_marginTop="30dp"
            android:lineSpacingExtra="6dp"
            android:textStyle="bold"
            android:text="Jai Lakshmi Mata, Maiya Jai Lakshmi Mata,\n
Tumko Nishdin Sevat, Shubh Labh Dena.\n\n

Chandan Vishesh Shobhit Roop,\n
Padkamal Tumhara Ujjwal.\n
Dukh Harta Sukhdata,\n
Bhakt Janon Ke Mann Ka Vardaan.\n\n

Shobha Tumhari Jyoti Bhari,\n
Dhan Sampatti Tumhari Aayi.\n
Shraddha Bhakti Jo Kare Tumko,\n
Har Saubhagya Ho Paayi.\n\n

Mahalakshmi Kar Do Kripa,\n
Man Ko Diyo Santosh.\n
Ghar Mein Laye Suvidha,\n
Bhakt Bhavan Mein Ho Har Kosh.\n\n

Jai Lakshmi Mata, Maiya Jai Lakshmi Mata,\n
Bhakta Janon Ke Kalyan Ki Data,\n
Dukh Harta Sukhdata,\n
Har Saubhagya Ke Kartaa." />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
