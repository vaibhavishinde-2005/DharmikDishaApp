<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Libra">

    <!-- 🔹 Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarLibra"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/system_on_error_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Libra"
        app:titleTextColor="#FFFFFF" />

    <!-- 🔹 Scroll area for content -->
    <ScrollView
        android:id="@+id/scrollViewLibra"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarLibra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Libra Symbol -->
            <ImageView
                android:id="@+id/libraSymbol"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/libra"
                android:contentDescription="Libra Icon" />

            <!-- Libra Title -->
            <TextView
                android:id="@+id/libraTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Libra(तुला)"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingTop="12dp" />

            <!-- Libra Description -->
            <TextView
                android:id="@+id/libraDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Libra is known for balance, harmony, and fairness. People born under Libra value relationships, peace, and beauty. They are social, diplomatic, and charming, but may struggle with indecision as they weigh all sides before choosing."
                android:textSize="16sp"
                android:paddingTop="16dp"
                android:lineSpacingExtra="4dp" />

            <!-- Traits Header -->
            <TextView
                android:id="@+id/traitsHeaderLibra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Traits"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Traits List -->
            <TextView
                android:id="@+id/traitsListLibra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Balanced\n• Diplomatic\n• Charming\n• Social\n• Idealistic\n• Indecisive"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

            <!-- Compatible Signs Header -->
            <TextView
                android:id="@+id/compatibleHeaderLibra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Compatible Signs"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Compatible Signs List -->
            <TextView
                android:id="@+id/compatibleSignsLibra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Gemini\n• Aquarius\n• Leo\n• Sagittarius"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
