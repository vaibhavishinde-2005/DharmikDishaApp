<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Top Toolbar -->

        <!-- Pandit Image -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/topToolbar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@android:color/system_on_error_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pandit Login"
                android:textColor="@android:color/white"
                android:textCursorDrawable="@android:drawable/ic_menu_recent_history"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="16dp"
                tools:layout_editor_absoluteY="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivHistory"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_recent_history" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="History"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

        <ImageView
            android:id="@+id/imgPandit"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:scaleType="centerCrop"
            android:src="@drawable/panditimg"
            app:layout_constraintTop_toBottomOf="@id/topToolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Pandit Full Name -->
        <EditText
            android:id="@+id/edtPanditName"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Pandit Full Name"
            android:padding="12dp"
            android:textSize="16sp"
            android:background="@drawable/edittext_background"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/imgPandit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email -->
        <EditText
            android:id="@+id/edtPanditEmail"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            app:layout_constraintTop_toBottomOf="@id/edtPanditName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Phone Number -->
        <EditText
            android:id="@+id/edtPanditPhone"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Phone Number"
            android:maxLength="10"
            android:inputType="phone"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            app:layout_constraintTop_toBottomOf="@id/edtPanditEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Experience -->
        <EditText
            android:id="@+id/edtPanditExperience"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Experience (Years)"
            android:inputType="number"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            app:layout_constraintTop_toBottomOf="@id/edtPanditPhone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Speciality -->
        <EditText
            android:id="@+id/edtPanditSpeciality"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Speciality (e.g.Satyanarayan,Sanskar)"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            app:layout_constraintTop_toBottomOf="@id/edtPanditExperience"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Address -->
        <EditText
            android:id="@+id/edtPanditAddress"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Address"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            app:layout_constraintTop_toBottomOf="@id/edtPanditSpeciality"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Dakshina -->
        <EditText
            android:id="@+id/edtPanditDakshina"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:hint="Dakshina Amount"
            android:inputType="number"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            app:layout_constraintTop_toBottomOf="@id/edtPanditAddress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Browse Pandit Photo -->
        <LinearLayout
            android:id="@+id/layoutBrowsePandit"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/edittext_background"
            android:orientation="horizontal"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/edtPanditDakshina"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/edtPanditFile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="false"
                android:hint="Upload Pandit Photo"
                android:padding="10dp"
                android:textSize="15sp"
                tools:ignore="TouchTargetSizeCheck" />

            <Button
                android:id="@+id/btnBrowsePandit"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Browse"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnPanditSave"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FF5722"
            android:text="Save Details"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/layoutBrowsePandit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
