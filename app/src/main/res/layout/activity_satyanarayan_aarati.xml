<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aartibackground"
    tools:context=".satyanarayan_aarati">

    <!-- TOP TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbarSatya"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/system_on_error_dark"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        app:title="Shree Satyanarayan Aarti" />

    <!-- SCROLLABLE AARTI -->
    <ScrollView
        android:id="@+id/scrollAartiSatya"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbarSatya"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/aartiTextSatya"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#5A3A1A"
            android:textSize="22sp"
            android:lineSpacingExtra="6dp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"

            android:text="Jai Jai Satyanarayan Bhagwan\n
Bhakton Ke Prabhu Tum Ho Mahan\n\n

Shree Vishnu Roop Dharay Aayo\n
Bhav Sagar Se Naath Bachayo\n
Paap Haran Bhay Bhanjan Bhole\n
Kar Do Jeevan Ujjwal Nirmal\n\n

Jai Jai Satyanarayan Bhagwan\n
Prem Se Karo Sab Dhyan\n\n

Dukh Daridra Door Tum Karte\n
Bhavbhakti Ke Deep Tum Bharte\n
Sukh Samriddhi Ki Barsat Banoge\n
Jo Sharan Mein Aaye Toh Taare\n\n

Pratham Katha Grihasthon Ko Saar\n
Doosri Mein Prem Ka Vichaar\n
Teesri Mein Bhakti Ka Sandesh\n
Chauthi Mein Vishwas Ki Jyoti Prachar\n\n

Jai Jai Satyanarayan Bhagwan\n
Kar Do Sab Par Kripa Kalyan" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
