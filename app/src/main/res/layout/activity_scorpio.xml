<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Scorpio">

    <!-- 🔹 Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarScorpio"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/system_on_error_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Scorpio"
        app:titleTextColor="#FFFFFF" />

    <!-- 🔹 Scroll area for content -->
    <ScrollView
        android:id="@+id/scrollViewScorpio"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarScorpio"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Scorpio Symbol -->
            <ImageView
                android:id="@+id/scorpioSymbol"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/scorpio"
                android:contentDescription="Scorpio Icon" />

            <!-- Scorpio Title -->
            <TextView
                android:id="@+id/scorpioTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scorpio(वृश्चिक)"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingTop="12dp" />

            <!-- Scorpio Description -->
            <TextView
                android:id="@+id/scorpioDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scorpio is known for intensity, passion, and strong willpower. People born under Scorpio are deep thinkers, loyal, and emotionally powerful. They value truth, transformation, and meaningful connections. Although magnetic and determined, they can sometimes be secretive or possessive."
                android:textSize="16sp"
                android:paddingTop="16dp"
                android:lineSpacingExtra="4dp" />

            <!-- Traits Header -->
            <TextView
                android:id="@+id/traitsHeaderScorpio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Traits"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Traits List -->
            <TextView
                android:id="@+id/traitsListScorpio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Passionate\n• Loyal\n• Intense\n• Strategic\n• Brave\n• Secretive"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

            <!-- Compatible Signs Header -->
            <TextView
                android:id="@+id/compatibleHeaderScorpio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Compatible Signs"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Compatible Signs List -->
            <TextView
                android:id="@+id/compatibleSignsScorpio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Cancer\n• Pisces\n• Virgo\n• Capricorn"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
