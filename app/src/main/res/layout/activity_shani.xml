<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aartibackground"
    tools:context=".Shani">

    <!-- TOP TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbarShani"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/system_on_error_dark"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Shree Shani Dev Aarti" />

    <!-- SCROLLABLE AARTI -->
    <ScrollView
        android:id="@+id/scrollAartiShani"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbarShani"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/aartiTextShani"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#5A3A1A"
            android:textSize="22sp"
            android:lineSpacingExtra="6dp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"

            android:text="Jai Jai Shani Dev Bhagwan\n
Kripa Karo Hey Muni Nandan\n\n

Kalaa Kayadha Peetambar Dhari\n
Dev Adhikari Shakti Tumhari\n
Dandadhari Doota Adhamana\n
Paapiyon Ko Tum Ho Dandana\n\n

Jai Jai Shani Dev Bhagwan\n
Bhakton Ke Parvardigar\n\n

Surya Nandan Tum Ho Prabhuvara\n
Navgrah Mein Balwan Adhikara\n
Shishya Tumhare Shree Hanuman\n
Sab Chinta Door Kare Bhagwan\n\n

Jo Sumiran Kare Shani Naam\n
Mite Sab Dukh, Ho Jam Kaam\n
Sada Bharosa Rahe Tumhara\n
Raksha Karna Shani Maharaj\n\n

Jai Jai Shani Dev Bhagwan\n
Kripa Drishti Ho Varadaan\n" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>