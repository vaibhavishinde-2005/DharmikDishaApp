<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Taurus">

    <!-- 🔹 Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarTaurus"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/system_on_error_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Taurus"
        app:titleTextColor="#FFFFFF" />

    <!-- 🔹 Scroll area for content -->
    <ScrollView
        android:id="@+id/scrollViewTaurus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarTaurus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Taurus Symbol -->
            <ImageView
                android:id="@+id/taurusSymbol"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/taurus"
                android:contentDescription="Taurus Icon" />

            <!-- Taurus Title -->
            <TextView
                android:id="@+id/taurusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Taurus(वृषभ)"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingTop="12dp" />

            <!-- Taurus Description -->
            <TextView
                android:id="@+id/taurusDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Taurus is known for stability, patience, and reliability. People born under Taurus value comfort, loyalty, and long-term commitments. They are dependable, grounded, and often very hardworking. Although gentle by nature, Taurus can be stubborn when it comes to change."
                android:textSize="16sp"
                android:paddingTop="16dp"
                android:lineSpacingExtra="4dp" />

            <!-- Traits Header -->
            <TextView
                android:id="@+id/traitsHeaderTaurus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Traits"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Traits List -->
            <TextView
                android:id="@+id/traitsListTaurus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Patient\n• Loyal\n• Determined\n• Practical\n• Loving\n• Stubborn"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

            <!-- Compatible Signs Header -->
            <TextView
                android:id="@+id/compatibleHeaderTaurus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Compatible Signs"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingTop="20dp" />

            <!-- Compatible Signs List -->
            <TextView
                android:id="@+id/compatibleSignsTaurus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Virgo\n• Capricorn\n• Cancer\n• Pisces"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
